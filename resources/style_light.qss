/* ═══════════════════════════════════════════════════════════════
   Claude DICOM Viewer — Light Theme
   Exact replica of claude.ai aesthetic (extracted from production)
   ═══════════════════════════════════════════════════════════════ */

/* ─── Palette (1:1 with Claude design tokens) ───
   --bg-100:  #FAF9F5  (page background, cream)
   --bg-200:  #F0EEE6  (panel / hover bg)
   --bg-300:  #E8E6DC  (active bg, borders soft)
   --bg-400:  #DCDAD2  (pressed)
   --text-000:#141413  (primary)
   --text-300:#3D3D3A  (secondary)
   --text-500:#73716C  (muted)
   --border:  rgba(20,20,19,0.10)
   --accent:  #D97757  (clay)
   --accent-hover: #C9633E
*/

* {
    outline: 0;
}

/* ─── Foundation ─── */
QMainWindow,
QWidget {
    background-color: #FAF9F5;
    color: #141413;
    font-family: "Segoe UI Variable", "Segoe UI", "Inter", "system-ui", -apple-system, sans-serif;
    font-size: 13px;
    font-weight: 430;
}

QMainWindow {
    background-color: #FAF9F5;
}

QStackedWidget,
QFrame,
QScrollArea > QWidget {
    background-color: transparent;
}

/* ─── Typography ─── */
QLabel {
    color: #141413;
    background: transparent;
}

QLabel#dialogTitle {
    font-family: "Georgia", "Charter", "Source Serif Pro", "Palatino Linotype", serif;
    font-size: 22px;
    font-weight: 500;
    color: #141413;
    padding: 4px 0px 2px 0px;
    letter-spacing: -0.01em;
}

QLabel#sectionLabel {
    font-family: "Georgia", "Charter", serif;
    font-size: 14px;
    color: #D97757;
    font-weight: 500;
}

QLabel#hintLabel {
    color: #73716C;
    font-style: italic;
    font-size: 12px;
    padding: 4px 2px;
}

QLabel#mutedLabel {
    color: #73716C;
    font-size: 12px;
}

/* ─── Menu Bar ─── */
QMenuBar {
    background-color: #FAF9F5;
    color: #141413;
    border-bottom: 1px solid rgba(20, 20, 19, 0.08);
    padding: 2px 6px;
    font-size: 13px;
    font-weight: 500;
}

QMenuBar::item {
    background-color: transparent;
    color: #141413;
    padding: 5px 10px;
    border-radius: 6px;
    margin: 1px 2px;
}

QMenuBar::item:selected,
QMenuBar::item:pressed {
    background-color: #F0EEE6;
}

QMenu {
    background-color: #FFFFFF;
    color: #141413;
    border: 1px solid rgba(20, 20, 19, 0.10);
    border-radius: 10px;
    padding: 5px;
    font-size: 13px;
}

QMenu::item {
    background-color: transparent;
    color: #141413;
    padding: 7px 18px 7px 14px;
    border-radius: 6px;
    margin: 1px 3px;
    min-width: 140px;
}

QMenu::item:selected {
    background-color: #F0EEE6;
    color: #141413;
}

QMenu::item:disabled {
    color: #B5B3AC;
}

QMenu::separator {
    height: 1px;
    background-color: rgba(20, 20, 19, 0.08);
    margin: 5px 10px;
}

QMenu::indicator {
    width: 14px;
    height: 14px;
    margin-left: 4px;
}

QMenu::icon {
    padding-left: 8px;
}

/* ─── ToolBar (Claude top bar) ─── */
QToolBar#mainToolbar {
    background-color: #FAF9F5;
    border: none;
    border-bottom: 1px solid rgba(20, 20, 19, 0.08);
    padding: 6px 10px;
    spacing: 2px;
    min-height: 48px;
}

QToolBar::separator {
    width: 1px;
    height: 20px;
    background-color: rgba(20, 20, 19, 0.10);
    margin: 6px 8px;
}

/* ─── ToolButtons (ghost style Claude buttons) ─── */
QToolButton {
    background-color: transparent;
    color: #3D3D3A;
    border: 1px solid transparent;
    border-radius: 8px;
    padding: 6px 9px;
    font-size: 13px;
    font-weight: 500;
    min-height: 22px;
}

QToolButton:hover {
    background-color: #F0EEE6;
    color: #141413;
}

QToolButton:pressed {
    background-color: #E8E6DC;
}

QToolButton:checked {
    background-color: #D97757;
    color: #FFFFFF;
    border: 1px solid #D97757;
}

QToolButton:checked:hover {
    background-color: #C9633E;
    border: 1px solid #C9633E;
}

QToolButton:disabled {
    color: #B5B3AC;
    background-color: transparent;
}

QToolButton::menu-indicator {
    image: none;
    width: 0px;
}

QToolButton::menu-button {
    border: none;
    width: 14px;
}

QToolButton[popupMode="2"] {
    padding-right: 16px;
}

/* ─── ComboBox (Claude-style selector) ─── */
QComboBox {
    background-color: #FFFFFF;
    color: #141413;
    border: 1px solid rgba(20, 20, 19, 0.10);
    border-radius: 8px;
    padding: 5px 32px 5px 12px;
    min-height: 24px;
    font-size: 13px;
    font-weight: 500;
    selection-background-color: #D97757;
    selection-color: #FFFFFF;
}

QComboBox:hover {
    background-color: #FFFFFF;
    border: 1px solid rgba(20, 20, 19, 0.18);
}

QComboBox:focus {
    border: 1px solid #D97757;
}

QComboBox:on {
    background-color: #FFFFFF;
    border: 1px solid #D97757;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 26px;
    border: none;
    background: transparent;
}

QComboBox::down-arrow {
    image: none;
    width: 10px;
    height: 10px;
    border-left: 1.5px solid #73716C;
    border-bottom: 1.5px solid #73716C;
    margin-right: 10px;
    margin-top: -4px;
}

QComboBox::down-arrow:hover {
    border-color: #141413;
}

QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    color: #141413;
    border: 1px solid rgba(20, 20, 19, 0.10);
    border-radius: 10px;
    selection-background-color: #F0EEE6;
    selection-color: #141413;
    padding: 6px;
    outline: none;
    margin-top: 4px;
}

QComboBox QAbstractItemView::item {
    padding: 8px 14px;
    border-radius: 6px;
    min-height: 26px;
    color: #141413;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #F0EEE6;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #F0EEE6;
    color: #141413;
}

/* ─── Slider (Claude style, very thin) ─── */
QSlider {
    min-height: 28px;
}

QSlider#adjustmentSlider {
    min-height: 28px;
}

QSlider::groove:horizontal {
    background: #E8E6DC;
    height: 4px;
    border: none;
    border-radius: 2px;
}

QSlider::sub-page:horizontal {
    background: #D97757;
    border-radius: 2px;
    height: 4px;
}

QSlider::add-page:horizontal {
    background: #E8E6DC;
    border-radius: 2px;
    height: 4px;
}

QSlider::handle:horizontal {
    background: #FFFFFF;
    border: 2px solid #D97757;
    width: 16px;
    height: 16px;
    margin: -7px 0;
    border-radius: 10px;
}

QSlider::handle:horizontal:hover {
    background: #D97757;
    border: 2px solid #D97757;
}

QSlider::handle:horizontal:pressed {
    background: #C9633E;
    border: 2px solid #C9633E;
}

/* ─── CheckBox (Claude-style) ─── */
QCheckBox {
    color: #141413;
    spacing: 9px;
    font-size: 13px;
    font-weight: 500;
    background: transparent;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 1.5px solid #B5B3AC;
    border-radius: 5px;
    background-color: #FFFFFF;
}

QCheckBox::indicator:hover {
    border: 1.5px solid #73716C;
}

QCheckBox::indicator:checked {
    background-color: #D97757;
    border: 1.5px solid #D97757;
    image: none;
}

QCheckBox::indicator:checked:hover {
    background-color: #C9633E;
    border: 1.5px solid #C9633E;
}

QCheckBox::indicator:disabled {
    background-color: #F0EEE6;
    border: 1.5px solid #E8E6DC;
}

/* ─── RadioButton ─── */
QRadioButton {
    color: #141413;
    spacing: 9px;
    font-size: 13px;
    background: transparent;
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 1.5px solid #B5B3AC;
    border-radius: 10px;
    background-color: #FFFFFF;
}

QRadioButton::indicator:checked {
    background-color: #FFFFFF;
    border: 5px solid #D97757;
}

/* ─── PushButton (primary Claude button) ─── */
QPushButton {
    background-color: #FFFFFF;
    color: #141413;
    border: 1px solid rgba(20, 20, 19, 0.12);
    border-radius: 8px;
    padding: 7px 18px;
    font-size: 13px;
    font-weight: 500;
    min-height: 26px;
}

QPushButton:hover {
    background-color: #F7F6F0;
    border: 1px solid rgba(20, 20, 19, 0.20);
}

QPushButton:pressed {
    background-color: #E8E6DC;
}

QPushButton:disabled {
    color: #B5B3AC;
    background-color: #FAF9F5;
    border: 1px solid rgba(20, 20, 19, 0.06);
}

QPushButton:default,
QPushButton#primaryButton {
    background-color: #141413;
    color: #FAF9F5;
    border: 1px solid #141413;
}

QPushButton:default:hover,
QPushButton#primaryButton:hover {
    background-color: #2D2C2A;
    border: 1px solid #2D2C2A;
}

QPushButton#accentButton {
    background-color: #D97757;
    color: #FFFFFF;
    border: 1px solid #D97757;
}

QPushButton#accentButton:hover {
    background-color: #C9633E;
    border: 1px solid #C9633E;
}

QPushButton#resetButton {
    background-color: transparent;
    border: 1px solid rgba(20, 20, 19, 0.12);
    color: #73716C;
}

QPushButton#resetButton:hover {
    background-color: #F0EEE6;
    color: #141413;
    border: 1px solid rgba(20, 20, 19, 0.20);
}

QPushButton#sidebarToggle {
    background-color: transparent;
    border: none;
    color: #73716C;
    font-size: 10px;
    padding: 0px;
    min-width: 18px;
    max-width: 18px;
}

QPushButton#sidebarToggle:hover {
    background-color: #F0EEE6;
    color: #141413;
}

/* ─── LineEdit (Claude chat input style) ─── */
QLineEdit {
    background-color: #FFFFFF;
    color: #141413;
    border: 1px solid rgba(20, 20, 19, 0.10);
    border-radius: 8px;
    padding: 7px 12px;
    font-size: 13px;
    selection-background-color: #D97757;
    selection-color: #FFFFFF;
    min-height: 24px;
}

QLineEdit:hover {
    border: 1px solid rgba(20, 20, 19, 0.18);
}

QLineEdit:focus {
    border: 1px solid #D97757;
    background-color: #FFFFFF;
}

QLineEdit:disabled {
    background-color: #F7F6F0;
    color: #B5B3AC;
}

QLineEdit#sidebarSearch {
    background-color: #FFFFFF;
    color: #141413;
    border: 1px solid rgba(20, 20, 19, 0.10);
    border-radius: 12px;
    padding: 9px 14px;
    font-size: 13px;
    min-height: 28px;
    margin: 10px 12px 8px 12px;
}

QLineEdit#sidebarSearch:focus {
    border: 1px solid #D97757;
}

/* ─── ScrollArea ─── */
QScrollArea {
    background-color: transparent;
    border: none;
}

QScrollArea > QWidget > QWidget {
    background-color: transparent;
}

/* ─── ScrollBar (thin, claude-style) ─── */
QScrollBar:vertical {
    background-color: transparent;
    width: 10px;
    margin: 4px 2px 4px 0px;
    border: none;
}

QScrollBar::handle:vertical {
    background-color: rgba(20, 20, 19, 0.18);
    border-radius: 4px;
    min-height: 40px;
}

QScrollBar::handle:vertical:hover {
    background-color: rgba(20, 20, 19, 0.30);
}

QScrollBar::handle:vertical:pressed {
    background-color: rgba(20, 20, 19, 0.42);
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
    border: none;
    background: none;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    background-color: transparent;
    height: 10px;
    margin: 0px 4px 2px 4px;
    border: none;
}

QScrollBar::handle:horizontal {
    background-color: rgba(20, 20, 19, 0.18);
    border-radius: 4px;
    min-width: 40px;
}

QScrollBar::handle:horizontal:hover {
    background-color: rgba(20, 20, 19, 0.30);
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
    border: none;
    background: none;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: none;
}

/* ─── GraphicsView (image viewport) ─── */
QGraphicsView {
    background-color: #F0EEE6;
    border: 1px solid rgba(20, 20, 19, 0.08);
    border-radius: 10px;
}

QGraphicsView#activeView {
    border: 1.5px solid #D97757;
}

/* ─── Sidebar widgets ─── */
QWidget#sidebarRoot {
    background-color: #F7F6F0;
    border-right: 1px solid rgba(20, 20, 19, 0.06);
}

QLabel#thumbnailLabel {
    background-color: #FFFFFF;
    border: 1px solid rgba(20, 20, 19, 0.08);
    border-radius: 10px;
    color: #73716C;
    font-size: 11px;
    padding: 4px;
}

QLabel#thumbnailLabel:hover {
    border: 1px solid #D97757;
}

QWidget#thumbnailItem {
    background-color: transparent;
    border-radius: 10px;
    padding: 4px;
}

QWidget#thumbnailItem:hover {
    background-color: #F0EEE6;
}

QLabel#thumbnailFilename {
    color: #3D3D3A;
    font-size: 11px;
    font-weight: 500;
    background: transparent;
}

/* ─── Dialog ─── */
QDialog {
    background-color: #FAF9F5;
    color: #141413;
}

QDialogButtonBox {
    button-layout: 0;
}

QDialogButtonBox QPushButton {
    min-width: 88px;
}

/* ─── TabWidget ─── */
QTabWidget::pane {
    border: 1px solid rgba(20, 20, 19, 0.10);
    border-radius: 10px;
    background-color: #FFFFFF;
    top: -1px;
}

QTabBar::tab {
    background-color: transparent;
    color: #73716C;
    border: none;
    padding: 8px 16px;
    margin-right: 4px;
    font-size: 13px;
    font-weight: 500;
}

QTabBar::tab:selected {
    color: #141413;
    border-bottom: 2px solid #D97757;
}

QTabBar::tab:hover:!selected {
    color: #141413;
}

/* ─── ToolTip ─── */
QToolTip {
    background-color: #141413;
    color: #FAF9F5;
    border: none;
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 12px;
    font-weight: 500;
    opacity: 240;
}

/* ─── ListWidget ─── */
QListWidget {
    background-color: #FFFFFF;
    border: 1px solid rgba(20, 20, 19, 0.10);
    border-radius: 10px;
    padding: 6px;
    outline: none;
    color: #141413;
}

QListWidget::item {
    padding: 8px 12px;
    border-radius: 6px;
    color: #141413;
    margin: 1px 0px;
}

QListWidget::item:hover {
    background-color: #F0EEE6;
}

QListWidget::item:selected {
    background-color: #D97757;
    color: #FFFFFF;
}

/* ─── SpinBox ─── */
QSpinBox,
QDoubleSpinBox {
    background-color: #FFFFFF;
    color: #141413;
    border: 1px solid rgba(20, 20, 19, 0.10);
    border-radius: 8px;
    padding: 5px 8px;
    min-height: 24px;
}

QSpinBox:hover,
QDoubleSpinBox:hover {
    border: 1px solid rgba(20, 20, 19, 0.20);
}

QSpinBox:focus,
QDoubleSpinBox:focus {
    border: 1px solid #D97757;
}

QSpinBox::up-button,
QSpinBox::down-button,
QDoubleSpinBox::up-button,
QDoubleSpinBox::down-button {
    width: 16px;
    border: none;
    background: transparent;
}

/* ─── GroupBox ─── */
QGroupBox {
    background-color: transparent;
    border: 1px solid rgba(20, 20, 19, 0.08);
    border-radius: 12px;
    margin-top: 16px;
    padding: 18px 14px 14px 14px;
    font-family: "Georgia", "Charter", serif;
    font-weight: 500;
    color: #141413;
    font-size: 14px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 14px;
    padding: 0 8px;
    background-color: #FAF9F5;
    color: #D97757;
}

/* ─── ProgressBar ─── */
QProgressBar {
    background-color: #E8E6DC;
    border: none;
    border-radius: 4px;
    height: 6px;
    text-align: center;
    color: transparent;
}

QProgressBar::chunk {
    background-color: #D97757;
    border-radius: 4px;
}

/* ─── Frame ─── */
QFrame[frameShape="4"], /* HLine */
QFrame[frameShape="5"]  /* VLine */ {
    color: rgba(20, 20, 19, 0.08);
    background-color: rgba(20, 20, 19, 0.08);
    border: none;
}

QFrame#separator {
    max-height: 1px;
    background-color: rgba(20, 20, 19, 0.08);
}

QFrame#card {
    background-color: #FFFFFF;
    border: 1px solid rgba(20, 20, 19, 0.06);
    border-radius: 12px;
    padding: 12px;
}

/* ─── StatusBar ─── */
QStatusBar {
    background-color: #FAF9F5;
    color: #73716C;
    border-top: 1px solid rgba(20, 20, 19, 0.06);
    font-size: 12px;
    padding: 2px 10px;
}

QStatusBar::item {
    border: none;
}

/* ─── Splitter ─── */
QSplitter::handle {
    background-color: transparent;
}

QSplitter::handle:horizontal {
    width: 1px;
    background-color: rgba(20, 20, 19, 0.08);
}

QSplitter::handle:vertical {
    height: 1px;
    background-color: rgba(20, 20, 19, 0.08);
}

QSplitter::handle:hover {
    background-color: #D97757;
}

/* ─── TextEdit (Info dialog) ─── */
QTextEdit,
QPlainTextEdit {
    background-color: #FFFFFF;
    color: #141413;
    border: 1px solid rgba(20, 20, 19, 0.08);
    border-radius: 10px;
    padding: 12px;
    selection-background-color: #D97757;
    selection-color: #FFFFFF;
    font-size: 13px;
}

QTextEdit:focus,
QPlainTextEdit:focus {
    border: 1px solid #D97757;
}

/* ─── Selection ─── */
QWidget:focus {
    outline: none;
}

/* ─── HeaderView (for tables) ─── */
QHeaderView::section {
    background-color: #F7F6F0;
    color: #73716C;
    border: none;
    border-bottom: 1px solid rgba(20, 20, 19, 0.08);
    padding: 8px 10px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
}

/* ─── TableView ─── */
QTableView {
    background-color: #FFFFFF;
    border: 1px solid rgba(20, 20, 19, 0.08);
    border-radius: 10px;
    gridline-color: rgba(20, 20, 19, 0.06);
    selection-background-color: #F0EEE6;
    selection-color: #141413;
    color: #141413;
}

QTableView::item {
    padding: 8px;
    border: none;
}

QTableView::item:selected {
    background-color: #F0EEE6;
    color: #141413;
}

/* ─── Sidebar specific ─── */
QPushButton#chatStyleButton {
    background-color: transparent;
    border: 1px solid transparent;
    border-radius: 8px;
    padding: 7px 12px;
    text-align: left;
    color: #3D3D3A;
    font-weight: 500;
}

QPushButton#chatStyleButton:hover {
    background-color: #F0EEE6;
    color: #141413;
}

QPushButton#chatStyleButton:checked {
    background-color: #F0EEE6;
    color: #141413;
}

/* ─── Active viewport highlight ─── */
QGraphicsView[active="true"] {
    border: 1.5px solid #D97757;
}

QFrame#loadingOverlay {
    background-color: rgba(250, 249, 245, 0.92);
    border-radius: 10px;
}

QLabel#loadingLabel {
    color: #3D3D3A;
    font-size: 14px;
    font-weight: 500;
    padding: 8px;
}

QFrame#focusControls {
    background-color: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(20, 20, 19, 0.10);
    border-radius: 14px;
}

QPushButton#focusInfoButton,
QPushButton#focusExitButton {
    min-height: 34px;
    padding: 0 14px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
}

QPushButton#focusInfoButton {
    color: #FFFFFF;
    background-color: #D97757;
}

QPushButton#focusInfoButton:hover {
    background-color: #C96849;
}

QLabel#focusHint {
    color: #FAF9F5;
    background-color: rgba(31, 30, 28, 0.90);
    border-radius: 9px;
    padding: 8px 12px;
    font-size: 13px;
}
